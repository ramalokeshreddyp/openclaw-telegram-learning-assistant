# ============================================================
# OpenClaw Telegram Learning Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is listed in .gitignore.
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Telegram Bot Configuration
# ----------------------------------------------------------
# Get this token from @BotFather on Telegram (/newbot command)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ----------------------------------------------------------
# REQUIRED: Ollama Configuration (used by docker-compose)
# ----------------------------------------------------------
# Points the OpenClaw gateway to the Ollama container
OLLAMA_HOST=http://ollama:11434

# ----------------------------------------------------------
# OPTIONAL: Cloud LLM Providers
# Uncomment one block below if you prefer a cloud model
# instead of the local Ollama default.
# ----------------------------------------------------------

# OpenAI (GPT-4o)
# OPENAI_API_KEY=<your-openai-api-key>

# Anthropic (Claude)
# ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ----------------------------------------------------------
# OPTIONAL: SearXNG (self-hosted web search)
# Only needed if you run: docker compose --profile with-searxng up
# ----------------------------------------------------------
# SEARXNG_URL=http://searxng:8888

# ----------------------------------------------------------
# OPTIONAL: Logging
# ----------------------------------------------------------
OPENCLAW_LOG_LEVEL=info
