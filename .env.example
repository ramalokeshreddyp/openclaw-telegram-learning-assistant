# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# LLM Provider Configuration (Ollama is default in docker-compose)
# Uncomment one of the following to use a cloud provider instead:

# OpenAI Configuration (for GPT-4o)
# OPENAI_API_KEY=sk-proj-your-openai-api-key

# Anthropic Configuration (for Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# SearXNG Configuration (optional, for self-hosted web search)
# SEARXNG_URL=http://localhost:8888
# If not set, the system will default to DuckDuckGo search

# OpenClaw Gateway Configuration
OPENCLAW_LOG_LEVEL=info
OLLAMA_HOST=http://ollama:11434
